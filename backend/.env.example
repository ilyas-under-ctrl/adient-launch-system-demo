# Copy this file to .env and adjust as needed.

# Used directly when running WITHOUT Docker (venv workflow).
# When running via docker-compose, DATABASE_URL is instead assembled
# from the POSTGRES_* values below and injected into the app container.
DATABASE_URL=sqlite:///./backend/launch_system_demo.db

POSTGRES_USER=launch_admin
POSTGRES_PASSWORD=launch_password
POSTGRES_DB=launch_system

# Used to sign the session cookie. Generate a real random value for anything
# beyond local prototyping, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-every-environment

# Minutes of inactivity before a session expires (SRS mentions 60 min idle expiry)
SESSION_IDLE_MINUTES=60

# Initial account seeded only when this username does not exist. Change both
# values before the first production start and rotate the password afterward.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
