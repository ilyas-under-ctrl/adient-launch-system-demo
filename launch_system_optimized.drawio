        <mxCell id="p6_n12" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FFF6D9;color:#7A5C00;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;v_actual_sales&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;VIEW / PROJECTION&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;confirmed delivery line only&lt;br&gt;sale_date = confirmation/actual date&lt;br&gt;quantity and unit_price_snapshot&lt;br&gt;delivery_value + allocated transport snapshot&lt;br&gt;no mutable actual_sales table&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#F2F2F2;strokeColor=#9E9E9E;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="view" dataName="v_actual_sales">
          <mxGeometry x="1050" y="911" width="420" height="151" as="geometry" />
        </mxCell>
        <mxCell id="p6_n13" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FFF6D9;color:#7A5C00;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;v_period_revenue&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;VIEW / PROJECTION&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;period / project / PO completion class&lt;br&gt;SUM confirmed line delivery values&lt;br&gt;PLUS transport cost snapshot once per shipment&lt;br&gt;current and next month supported&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#F2F2F2;strokeColor=#9E9E9E;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="view" dataName="v_period_revenue">
          <mxGeometry x="1555" y="911" width="420" height="134" as="geometry" />
        </mxCell>
        <mxCell id="p6_n14" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FFF6D9;color:#7A5C00;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;v_forecast_vs_actual&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;VIEW / PROJECTION&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;month / project / FGPN&lt;br&gt;forecast qty/value from active forecast&lt;br&gt;actual qty/value from confirmations&lt;br&gt;variance qty/value&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#F2F2F2;strokeColor=#9E9E9E;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="view" dataName="v_forecast_vs_actual">
          <mxGeometry x="2060" y="911" width="420" height="134" as="geometry" />
        </mxCell>
        <mxCell id="p6_note0" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Historical value invariant&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;A shipment selects the effective delivery-method cost record and copies amount/currency. Each line selects the effective FGPN price record and copies price/currency. Later price or cost changes create new effective-dated rows and never change historical delivery or forecast values.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Historical value invariant">
          <mxGeometry x="40" y="1285" width="1215" height="109" as="geometry" />
        </mxCell>
        <mxCell id="p6_note1" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Confirmation/quantity gate&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;A shipment becomes Delivered only when a delivery_confirmations row exists. A deferred trigger locks the delivery facts at confirmation and ensures cumulative confirmed quantity for each stable PO item does not exceed the current ordered quantity. The final PO status also requires remaining quantity zero.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Confirmation/quantity gate">
          <mxGeometry x="1345" y="1285" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p6_note2" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Finance derivation&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Actual sales and revenue are views over confirmed immutable delivery snapshots, preventing duplicate accounting facts. Transport cost is added once per shipment, not once per line. Invoice mandatory/conditional behavior remains a policy setting until OP-11 is resolved.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Finance derivation">
          <mxGeometry x="40" y="1447" width="1215" height="109" as="geometry" />
        </mxCell>
