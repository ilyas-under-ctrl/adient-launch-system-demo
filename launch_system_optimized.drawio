        <mxCell id="p5_n4" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#EAF6EA;color:#2F6B2F;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;inventory_events&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;event_type inventory_event_type NOT NULL&lt;br&gt;source_system varchar(40) NOT NULL&lt;br&gt;source_event_key varchar(120) NOT NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; idempotency_key uuid NOT NULL&lt;br&gt;payload_hash bytea NOT NULL&lt;br&gt;occurred_at timestamptz NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; created_by uuid NULL -&amp;gt; users&lt;br&gt;created_at timestamptz NOT NULL&lt;br&gt;posted_at timestamptz NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; reversal_of_event_id uuid NULL -&amp;gt; inventory_events&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (source_system,source_event_key)&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; reversal_of_event_id&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; immutable; payload key reuse must match hash&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="inventory_events">
