        <mxCell id="p5_title" value="&lt;div style=&quot;font-family:Arial;color:#34495E;font-size:15px;line-height:1.35&quot;&gt;&lt;b&gt;05 Inventory Ledger/Warehouse Transfer&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Stock pools/locations, immutable exact-once ledger postings, future arrivals, and signed warehouse-to-manufacturing transfer.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF0F6;strokeColor=#52677A;strokeWidth=2;align=left;verticalAlign=middle;spacing=14;" vertex="1" parent="1" dataKind="module" dataName="05 Inventory Ledger/Warehouse Transfer">
