        <mxCell id="p4_n18" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#F2E9FF;color:#5B3B72;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;bom_impact_review_items&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; review_id uuid NOT NULL -&amp;gt; bom_impact_reviews&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; material_id uuid NOT NULL -&amp;gt; materials&lt;br&gt;old_required_qty numeric(20,4) NOT NULL&lt;br&gt;new_required_qty numeric(20,4) NOT NULL&lt;br&gt;difference_qty numeric(20,4) NOT NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (review_id,material_id)&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; difference=new-old&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#9673A6;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="bom_impact_review_items">
          <mxGeometry x="1555" y="1321" width="420" height="202" as="geometry" />
