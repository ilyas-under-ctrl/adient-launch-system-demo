        <mxCell id="p3_n8" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FFF1E6;color:#8A4B08;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;po_version_comparison_items&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; comparison_id uuid NOT NULL -&amp;gt; po_version_comparisons&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; po_item_id uuid NULL -&amp;gt; purchase_order_items&lt;br&gt;scope comparison_scope NOT NULL&lt;br&gt;field_key po_field_key NOT NULL&lt;br&gt;value_a text NULL&lt;br&gt;value_b text NULL&lt;br&gt;change_type change_type NOT NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; NULLS NOT DISTINCT (comparison_id,po_item_id,scope,field_key)&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#D79B00;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="po_version_comparison_items">
