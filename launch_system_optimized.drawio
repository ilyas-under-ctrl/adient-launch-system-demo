        <mxCell id="p5_n16" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#E5F6F6;color:#1D6668;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;delivery_code_access_events&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id bigint GENERATED IDENTITY&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; delivery_code_id uuid NULL -&amp;gt; delivery_codes&lt;br&gt;entered_code_digest bytea NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; entered_by uuid NULL -&amp;gt; users&lt;br&gt;entered_at timestamptz NOT NULL&lt;br&gt;success boolean NOT NULL&lt;br&gt;failure_reason varchar(80) NULL&lt;br&gt;ip_address inet NULL&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; immutable&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#4FA3A5;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="delivery_code_access_events">
