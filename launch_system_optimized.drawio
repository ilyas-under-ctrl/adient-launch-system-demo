          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2_e1" value="1 to 0..*" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;strokeWidth=1.1;strokeColor=#64748B;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p2_n1" target="p2_n2" dataKind="relationship">
