        <mxCell id="p2_n18" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#E8F1FB;color:#1F4E79;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;document_encryption_keys&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;provider varchar(40) NOT NULL&lt;br&gt;kms_key_ref varchar(255) NOT NULL&lt;br&gt;key_version varchar(80) NOT NULL&lt;br&gt;algorithm varchar(40) NOT NULL&lt;br&gt;status key_status NOT NULL&lt;br&gt;activated_at timestamptz NOT NULL&lt;br&gt;retired_at timestamptz NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (kms_key_ref,key_version)&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; external KMS reference only; never key material&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#6C8EBF;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="document_encryption_keys">
          <mxGeometry x="1555" y="1049" width="420" height="236" as="geometry" />
        </mxCell>
        <mxCell id="p2_n19" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#E8F1FB;color:#1F4E79;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;documents&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;document_type document_type NOT NULL&lt;br&gt;file_name varchar(255) NOT NULL&lt;br&gt;mime_type varchar(100) NOT NULL&lt;br&gt;byte_size bigint NOT NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; storage_key text NOT NULL&lt;br&gt;checksum_sha256 bytea NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; encryption_key_id uuid NOT NULL -&amp;gt; document_encryption_keys&lt;br&gt;retention_class varchar(60) NOT NULL&lt;br&gt;retain_until timestamptz NULL&lt;br&gt;legal_hold boolean NOT NULL DEFAULT false&lt;br&gt;status document_status NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; uploaded_by uuid NULL -&amp;gt; users&lt;br&gt;uploaded_at timestamptz NOT NULL&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; byte_size&amp;gt;0; purge blocked by hold/retention&lt;br&gt;&lt;span style=&quot;color:#555555;font-weight:700&quot;&gt;IX&lt;/span&gt; checksum_sha256&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#6C8EBF;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="documents">
          <mxGeometry x="2060" y="1049" width="420" height="355" as="geometry" />
        </mxCell>
        <mxCell id="p2_n20" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#E8F1FB;color:#1F4E79;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;document_signatures&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; document_id uuid NOT NULL -&amp;gt; documents&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; manufacturing_receiver_id uuid NULL -&amp;gt; manufacturing_receivers&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; signer_user_id uuid NULL -&amp;gt; users&lt;br&gt;signer_name_snapshot varchar(150) NOT NULL&lt;br&gt;signature_role varchar(80) NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; uploaded_by uuid NOT NULL -&amp;gt; users&lt;br&gt;signed_at timestamptz NULL&lt;br&gt;recorded_at timestamptz NOT NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (document_id,signature_role,signer_name_snapshot)&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; exactly one typed signer identity when known&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#6C8EBF;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="document_signatures">
          <mxGeometry x="40" y="1459" width="420" height="270" as="geometry" />
        </mxCell>
        <mxCell id="p2_n21" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#EDF1F5;color:#34495E;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;system_settings&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; setting_key varchar(100)&lt;br&gt;setting_value jsonb NOT NULL&lt;br&gt;value_schema_version integer NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; updated_by uuid NOT NULL -&amp;gt; users&lt;br&gt;updated_at timestamptz NOT NULL&lt;br&gt;row_version bigint NOT NULL DEFAULT 1&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#7B8A97;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="system_settings">
          <mxGeometry x="545" y="1459" width="420" height="168" as="geometry" />
        </mxCell>
        <mxCell id="p2_note0" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Session and lock invariant&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;A revoked, expired, inactive, or 60-minutes-idle session cannot authorize a request. Password lock occurs after 5 consecutive failures. Every mutable aggregate save includes WHERE row_version = :loaded_version and increments the version; zero updated rows means reload.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Session and lock invariant">
          <mxGeometry x="40" y="1799" width="1215" height="109" as="geometry" />
        </mxCell>
        <mxCell id="p2_note1" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Role and project-scope invariant&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;user_role_assignments preserves every grant/revocation; a partial unique index permits at most one open role row and a deferred trigger requires exactly one for every active user. users.current_role_id is only a checked cache of that row. project_assignments grants project visibility independently and temporally; it carries no second role that could disagree.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Role and project-scope invariant">
          <mxGeometry x="1345" y="1799" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p2_note2" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Typed reference integrity&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Customers, contacts, manufacturing receivers, delivery methods, material types, development levels, and FGPNs are authoritative typed masters. reference_list_items remains only for non-authoritative extensions; no core business FK may point to it. Inactive master rows remain readable historically.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Typed reference integrity">
          <mxGeometry x="40" y="1961" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p2_note3" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Document invariant&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;File bytes are immutable in encrypted object storage; a replacement is a new documents row. Only an external KMS key reference/version is stored. Retention class, retain-until, and legal hold gate purge. Signed documents retain typed signer identity, signer snapshot, uploader, checksum, and content-sniffing evidence.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Document invariant">
          <mxGeometry x="1345" y="1961" width="1215" height="127" as="geometry" />
        </mxCell>
