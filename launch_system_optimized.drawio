<?xml version='1.0' encoding='utf-8'?>
<mxfile host="app.diagrams.net" modified="2026-07-10T11:10:26.975479+00:00" agent="OpenAI Codex - Launch System ERD generator" version="24.7.17" type="device" compressed="false">
  <diagram id="launch-page-00" name="00 Review/Assumptions">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2600" pageHeight="2400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p0_title" value="&lt;div style=&quot;font-family:Arial;color:#34495E;font-size:15px;line-height:1.35&quot;&gt;&lt;b&gt;00 Review/Assumptions&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Verdict, PostgreSQL conventions, resolved design gaps, and business decisions still required.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF0F6;strokeColor=#52677A;strokeWidth=2;align=left;verticalAlign=middle;spacing=14;" vertex="1" parent="1" dataKind="module" dataName="00 Review/Assumptions">
          <mxGeometry x="40" y="25" width="2520" height="72" as="geometry" />
        </mxCell>
        <mxCell id="p0_note0" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Review verdict&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;The supplied DBML is a useful first draft but is not production-ready. It mixes mutable balances with history, keys PO lines by version, models BOM changes as intervals rather than full snapshots, and lacks reproducible policy snapshots, exact-once inventory posting, signer identity, sessions, outbox delivery, and tamper-evident audit chaining. This ERD corrects those structural gaps.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Review verdict">
          <mxGeometry x="40" y="140" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p0_note1" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;PostgreSQL 16+ conventions&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Use uuid identifiers (prefer UUIDv7 generated by the application or an approved extension), timestamptz in UTC for instants, date for business dates, numeric(20,4) for quantities/prices, char(n) only for confirmed fixed-length codes, jsonb only for immutable snapshots/payloads, and object storage for file bytes. Enable RLS by project and revoke UPDATE/DELETE on append-only tables.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="PostgreSQL 16+ conventions">
          <mxGeometry x="1345" y="140" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p0_note2" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Stable facts vs projections&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;PO versions, BOM revisions, launch items, partial-production events, inventory postings, status history, confirmations, signatures, price/cost periods, and audit events are immutable facts. Current PO progress, stock balances, actual sales, revenue, threshold state, and dashboards are views/materialized projections. Never repair history by overwriting a fact; append a correction/reversal.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Stable facts vs projections">
          <mxGeometry x="40" y="302" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p0_note3" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Major reconciliations&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Stable purchase_order_items survive every PO version and join typed launch, production, and confirmed-delivery facts. All 20 extracted fields retain validation detail; immutable PO rows snapshot customer/contact/FGPN/development labels. BOM revisions are complete xlsx snapshots. Simulations snapshot multi-PO progress plus warehouse/WIP/transit/planned stock and dated future arrivals.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Major reconciliations">
          <mxGeometry x="1345" y="302" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p0_note4" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Inventory correctness&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Locations belong to explicit stock pools and project_stock_pools defines shared versus project-scoped access. Every stock-changing command creates one inventory_event and immutable signed postings atomically. UNIQUE source/idempotency keys plus payload_hash give exactly-once acceptance. Balance views are projections, never manually edited.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Inventory correctness">
          <mxGeometry x="40" y="464" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p0_note5" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Documents and audit&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;documents stores immutable SHA-256 metadata, an external KMS key/version reference, and retention/legal-hold controls. Domain rows hold normal FKs to documents; signatures retain typed signer identity and display snapshot. audit_events is append-only and hash-chained, and outbox_events commits with the business fact.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Documents and audit">
          <mxGeometry x="1345" y="464" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p0_note6" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Open points OP-01 to OP-04&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;OP-01 FGPN length remains configurable; no false length CHECK is imposed until a real example is approved. OP-02/03/04 role scope remains policy data through permissions, role_permissions, one temporal active user role, temporal project assignments, and server-side RLS. Plant Manager stays read-only, Launch Manager writes assigned projects, and Warehouse Personnel remains least-privilege pending confirmation.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Open points OP-01 to OP-04">
          <mxGeometry x="40" y="626" width="1215" height="145" as="geometry" />
        </mxCell>
        <mxCell id="p0_note7" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Open points OP-05 to OP-09&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;OP-05 status moves are unique from/to rows with allowed roles in po_status_transition_roles; backward moves require a reason. OP-06 priority/tie-break rules are immutable simulation policy versions. OP-07 confirmation requires explicit evidence, with accepted form configurable. OP-08 delivery methods are typed master data. OP-09 safety coefficient defaults to 2 only as versioned policy data.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Open points OP-05 to OP-09">
          <mxGeometry x="1345" y="626" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p0_note8" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Open points OP-10 to OP-13&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;OP-10 signed warehouse receipt validation stores validator and time before the inventory event is posted. OP-11 invoice requirement is a system setting/policy rule. OP-12 future-simulation drafts are persisted as documents. OP-13 code TTL is a setting seeded to 48 hours until business sign-off; codes are hashed, unique, expiring, and single-use.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Open points OP-10 to OP-13">
          <mxGeometry x="40" y="806" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p0_note9" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Key data rules&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;PO number: char(10), length 10. PO part number: char(7). Color code: char(4). PO level: varchar(6). Unit price and quantities: numeric(20,4), non-negative/positive as appropriate. Descriptions: varchar(50). Material part number: varchar(10). PO/BOM/CutMan/signed/invoice file formats are enforced by domain checks plus content sniffing; CutMan SQL is parsed as data and never executed.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Key data rules">
          <mxGeometry x="1345" y="806" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p0_note10" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Concurrency and lifecycle&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Mutable aggregates carry row_version bigint for optimistic locking. user_sessions implements the configurable 60-minute inactivity timeout and revocation. Deactivate reference/users instead of deleting. Deferred constraint triggers enforce cross-table rules such as same-project references, final launch meeting minutes, confirmation before Delivered, and delivered quantity not exceeding the current ordered quantity.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Concurrency and lifecycle">
          <mxGeometry x="40" y="968" width="1215" height="145" as="geometry" />
        </mxCell>
        <mxCell id="p0_note11" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Blue IAM/reference | Orange PO | Purple BOM/simulation | Green inventory | Teal deliveries | Gold finance | Red audit | Grey views/projections | Yellow invariants/open decisions. PK/FK/UQ/CK/IX/GEN mean primary key, foreign key, unique, check, index, and generated value.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Legend">
          <mxGeometry x="1345" y="968" width="1215" height="109" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="launch-page-01" name="01 Overview">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2600" pageHeight="2400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p1_title" value="&lt;div style=&quot;font-family:Arial;color:#34495E;font-size:15px;line-height:1.35&quot;&gt;&lt;b&gt;01 Overview&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;End-to-end business flow. Detailed tables and constraints are on pages 02-07.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF0F6;strokeColor=#52677A;strokeWidth=2;align=left;verticalAlign=middle;spacing=14;" vertex="1" parent="1" dataKind="module" dataName="01 Overview">
          <mxGeometry x="40" y="25" width="2520" height="72" as="geometry" />
        </mxCell>
        <mxCell id="p1_n0" value="&lt;div style=&quot;font-family:Arial;color:#1F4E79;font-size:15px;line-height:1.35&quot;&gt;&lt;b&gt;IAM &amp;amp; project scope&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;users, sessions, roles, assignments, references, documents&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#E8F1FB;strokeColor=#6C8EBF;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;spacing=12;" vertex="1" parent="1" dataKind="module" dataName="IAM &amp; project scope">
          <mxGeometry x="40" y="125" width="420" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p1_n1" value="&lt;div style=&quot;font-family:Arial;color:#8A4B08;font-size:15px;line-height:1.35&quot;&gt;&lt;b&gt;PO intake &amp;amp; versions&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;PDF audit copy, extraction review, stable items, immutable versions, status&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF1E6;strokeColor=#D79B00;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;spacing=12;" vertex="1" parent="1" dataKind="module" dataName="PO intake &amp; versions">
          <mxGeometry x="545" y="125" width="420" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p1_n2" value="&lt;div style=&quot;font-family:Arial;color:#5B3B72;font-size:15px;line-height:1.35&quot;&gt;&lt;b&gt;BOM &amp;amp; simulation&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;xlsx full snapshots, policy snapshots, multi-PO allocation, launch gate&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#F2E9FF;strokeColor=#9673A6;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;spacing=12;" vertex="1" parent="1" dataKind="module" dataName="BOM &amp; simulation">
          <mxGeometry x="1050" y="125" width="420" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p1_n3" value="&lt;div style=&quot;font-family:Arial;color:#2F6B2F;font-size:15px;line-height:1.35&quot;&gt;&lt;b&gt;Inventory ledger&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;pools + locations, exact-once events/postings, CutMan, arrivals&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#EAF6EA;strokeColor=#82B366;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;spacing=12;" vertex="1" parent="1" dataKind="module" dataName="Inventory ledger">
          <mxGeometry x="1555" y="125" width="420" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p1_n4" value="&lt;div style=&quot;font-family:Arial;color:#1D6668;font-size:15px;line-height:1.35&quot;&gt;&lt;b&gt;Warehouse transfer&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;meeting-gated instruction lines, one-time code, signed receipt&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#E5F6F6;strokeColor=#4FA3A5;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;spacing=12;" vertex="1" parent="1" dataKind="module" dataName="Warehouse transfer">
          <mxGeometry x="2060" y="125" width="420" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p1_n5" value="&lt;div style=&quot;font-family:Arial;color:#1D6668;font-size:15px;line-height:1.35&quot;&gt;&lt;b&gt;Customer delivery&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;instruction, partial shipments, explicit confirmation evidence&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#E5F6F6;strokeColor=#4FA3A5;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;spacing=12;" vertex="1" parent="1" dataKind="module" dataName="Customer delivery">
          <mxGeometry x="40" y="295" width="420" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p1_n6" value="&lt;div style=&quot;font-family:Arial;color:#7A5C00;font-size:15px;line-height:1.35&quot;&gt;&lt;b&gt;Finance&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;effective prices/costs, immutable delivery snapshots, forecast vs actual&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF6D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;spacing=12;" vertex="1" parent="1" dataKind="module" dataName="Finance">
          <mxGeometry x="545" y="295" width="420" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p1_n7" value="&lt;div style=&quot;font-family:Arial;color:#7F2420;font-size:15px;line-height:1.35&quot;&gt;&lt;b&gt;Audit &amp;amp; integration&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;hash chain, traceability package, alerts, transactional outbox&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FBE8E7;strokeColor=#B85450;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;spacing=12;" vertex="1" parent="1" dataKind="module" dataName="Audit &amp; integration">
          <mxGeometry x="1050" y="295" width="420" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p1_n8" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#EDF1F5;color:#34495E;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;v_operational_dashboard&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;VIEW / PROJECTION&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;project-scoped exception panels&lt;br&gt;PO / stock / launch / delivery / finance&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#F2F2F2;strokeColor=#9E9E9E;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="view" dataName="v_operational_dashboard">
          <mxGeometry x="1555" y="295" width="420" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p1_note0" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Boundary rule&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Every operational row is project-scoped directly or through a mandatory FK path. Server-side authorization/RLS uses project_assignments; UI hiding is not a security control.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Boundary rule">
          <mxGeometry x="40" y="480" width="1215" height="109" as="geometry" />
        </mxCell>
        <mxCell id="p1_e0" value="authorizes / scopes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;strokeWidth=1.1;strokeColor=#64748B;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p1_n0" target="p1_n1" dataKind="relationship">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1_e1" value="versioned demand" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;strokeWidth=1.1;strokeColor=#64748B;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p1_n1" target="p1_n2" dataKind="relationship">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1_e2" value="reads snapshots" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;strokeWidth=1.1;strokeColor=#64748B;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p1_n2" target="p1_n3" dataKind="relationship">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1_e3" value="approved launch" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;strokeWidth=1.1;strokeColor=#64748B;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p1_n2" target="p1_n4" dataKind="relationship">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1_e4" value="posts transfer" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;strokeWidth=1.1;strokeColor=#64748B;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p1_n3" target="p1_n4" dataKind="relationship">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p1_e5" value="manufactured goods" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;strokeWidth=1.1;strokeColor=#64748B;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p1_n4" target="p1_n5" dataKind="relationship">
