        <mxCell id="p6_title" value="&lt;div style=&quot;font-family:Arial;color:#34495E;font-size:15px;line-height:1.35&quot;&gt;&lt;b&gt;06 Customer Delivery/Finance&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Partial shipments, confirmation evidence, immutable price/transport snapshots, effective-dated rates, forecasts, and derived actuals.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF0F6;strokeColor=#52677A;strokeWidth=2;align=left;verticalAlign=middle;spacing=14;" vertex="1" parent="1" dataKind="module" dataName="06 Customer Delivery/Finance">
          <mxGeometry x="40" y="25" width="2520" height="72" as="geometry" />
        </mxCell>
        <mxCell id="p6_n0" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#E5F6F6;color:#1D6668;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;customer_delivery_instructions&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; project_id uuid NOT NULL -&amp;gt; projects&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; purchase_order_id uuid NOT NULL -&amp;gt; purchase_orders&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; delivery_method_id uuid NOT NULL -&amp;gt; delivery_methods&lt;br&gt;planned_delivery_date date NULL&lt;br&gt;planned_period daterange NULL&lt;br&gt;status customer_instruction_status NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; generated_by uuid NOT NULL -&amp;gt; users&lt;br&gt;generated_at timestamptz NOT NULL&lt;br&gt;row_version bigint NOT NULL DEFAULT 1&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#4FA3A5;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="customer_delivery_instructions">
