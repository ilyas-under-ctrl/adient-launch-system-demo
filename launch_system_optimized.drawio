        <mxCell id="p7_title" value="&lt;div style=&quot;font-family:Arial;color:#34495E;font-size:15px;line-height:1.35&quot;&gt;&lt;b&gt;07 Audit/Alerts/Cross-cutting&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Tamper-evident audit streams, traceability packages, SRS dashboard exceptions, request idempotency, and transactional outbox.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF0F6;strokeColor=#52677A;strokeWidth=2;align=left;verticalAlign=middle;spacing=14;" vertex="1" parent="1" dataKind="module" dataName="07 Audit/Alerts/Cross-cutting">
