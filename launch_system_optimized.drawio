        <mxCell id="p2_e3" value="1 user to 1 active + history" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;strokeWidth=1.1;strokeColor=#64748B;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p2_n3" target="p2_n4" dataKind="relationship">
          <mxGeometry relative="1" as="geometry" />
