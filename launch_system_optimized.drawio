to_launch_qty&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#9673A6;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="simulation_item_results">
