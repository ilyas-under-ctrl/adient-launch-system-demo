        <mxCell id="p7_n3" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FBE8E7;color:#7F2420;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;outbox_events&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; audit_event_id uuid NULL -&amp;gt; audit_events&lt;br&gt;aggregate_type varchar(80) NOT NULL&lt;br&gt;aggregate_id uuid NOT NULL&lt;br&gt;event_type varchar(100) NOT NULL&lt;br&gt;topic varchar(120) NOT NULL&lt;br&gt;payload jsonb NOT NULL&lt;br&gt;occurred_at timestamptz NOT NULL&lt;br&gt;available_at timestamptz NOT NULL&lt;br&gt;published_at timestamptz NULL&lt;br&gt;attempt_count integer NOT NULL DEFAULT 0&lt;br&gt;last_error text NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; audit_event_id&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (aggregate_type,aggregate_id,event_type,occurred_at)&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#B85450;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="outbox_events">
          <mxGeometry x="1555" y="125" width="420" height="304" as="geometry" />
        </mxCell>
        <mxCell id="p7_n4" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FBE8E7;color:#7F2420;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;dashboard_alerts&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; project_id uuid NULL -&amp;gt; projects&lt;br&gt;alert_type alert_type NOT NULL&lt;br&gt;entity_type varchar(80) NOT NULL&lt;br&gt;entity_id uuid NOT NULL&lt;br&gt;severity alert_severity NOT NULL&lt;br&gt;message text NOT NULL&lt;br&gt;dedupe_key varchar(200) NOT NULL&lt;br&gt;status alert_status NOT NULL&lt;br&gt;created_at timestamptz NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; acknowledged_by uuid NULL -&amp;gt; users&lt;br&gt;acknowledged_at timestamptz NULL&lt;br&gt;resolved_at timestamptz NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; partial dedupe_key WHERE status='open'&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; SRS exceptions only; no notification table&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#B85450;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="dashboard_alerts">
          <mxGeometry x="2060" y="125" width="420" height="321" as="geometry" />
        </mxCell>
        <mxCell id="p7_n5" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FBE8E7;color:#7F2420;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;audit_packages&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; project_id uuid NOT NULL -&amp;gt; projects&lt;br&gt;as_of_at timestamptz NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; document_id uuid NOT NULL -&amp;gt; documents&lt;br&gt;manifest_hash bytea NOT NULL&lt;br&gt;status audit_package_status NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; generated_by uuid NOT NULL -&amp;gt; users&lt;br&gt;generated_at timestamptz NOT NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; document_id&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (project_id,as_of_at,manifest_hash)&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#B85450;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="audit_packages">
          <mxGeometry x="40" y="569" width="420" height="236" as="geometry" />
        </mxCell>
        <mxCell id="p7_n6" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FBE8E7;color:#7F2420;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;audit_package_items&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; audit_package_id uuid NOT NULL -&amp;gt; audit_packages&lt;br&gt;ordinal integer NOT NULL&lt;br&gt;entity_type varchar(80) NOT NULL&lt;br&gt;entity_id uuid NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; document_id uuid NULL -&amp;gt; documents&lt;br&gt;item_hash bytea NOT NULL&lt;br&gt;included_at timestamptz NOT NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (audit_package_id,ordinal)&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; NULLS NOT DISTINCT (audit_package_id,entity_type,entity_id,document_id)&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#B85450;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="audit_package_items">
          <mxGeometry x="545" y="569" width="420" height="253" as="geometry" />
        </mxCell>
        <mxCell id="p7_n7" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FBE8E7;color:#7F2420;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;traceability_links&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;source_entity_type varchar(80) NOT NULL&lt;br&gt;source_entity_id uuid NOT NULL&lt;br&gt;target_entity_type varchar(80) NOT NULL&lt;br&gt;target_entity_id uuid NOT NULL&lt;br&gt;relationship_type varchar(80) NOT NULL&lt;br&gt;created_at timestamptz NOT NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (source_entity_type,source_entity_id,target_entity_type,target_entity_id,relationship_type)&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; append-only; validated entity-type registry&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#B85450;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="traceability_links">
          <mxGeometry x="1050" y="569" width="420" height="236" as="geometry" />
        </mxCell>
        <mxCell id="p7_n8" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FBE8E7;color:#7F2420;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;v_project_lifecycle_audit&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;VIEW / PROJECTION&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;project + PO versions/corrections/status&lt;br&gt;BOM/simulation/policy/meeting minutes&lt;br&gt;inventory + warehouse/customer deliveries&lt;br&gt;confirmations/invoices/finance&lt;br&gt;documents/signers and event hashes&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#F2F2F2;strokeColor=#9E9E9E;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="view" dataName="v_project_lifecycle_audit">
          <mxGeometry x="1555" y="569" width="420" height="151" as="geometry" />
        </mxCell>
        <mxCell id="p7_n9" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FBE8E7;color:#7F2420;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;v_actionable_dashboard&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;VIEW / PROJECTION&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;project-scoped RLS&lt;br&gt;open alerts first&lt;br&gt;stock &amp;lt;= threshold&lt;br&gt;delivery confirmation overdue&lt;br&gt;missing materials&lt;br&gt;launch missing meeting minutes&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#F2F2F2;strokeColor=#9E9E9E;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="view" dataName="v_actionable_dashboard">
          <mxGeometry x="2060" y="569" width="420" height="168" as="geometry" />
        </mxCell>
        <mxCell id="p7_note0" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Append-only hash chain&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Only a SECURITY DEFINER append function can insert audit events. It locks audit_stream_heads, assigns the next sequence, canonicalizes the event payload, computes SHA-256(previous hash + payload), inserts the event, and advances the head in one transaction. UPDATE/DELETE/TRUNCATE are revoked; periodic external anchor/checkpoint is recommended.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Append-only hash chain">
          <mxGeometry x="40" y="892" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p7_note1" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Transactional outbox&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;The business fact, audit event, and outbox row commit together. A worker publishes with retry and marks published_at; consumers deduplicate by outbox id. This avoids dual-write loss. outbox_events is integration plumbing, not a user notification subsystem.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Transactional outbox">
          <mxGeometry x="1345" y="892" width="1215" height="109" as="geometry" />
        </mxCell>
        <mxCell id="p7_note2" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Alerts and traceability&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;dashboard_alerts is limited to SRS exception states and uses dedupe keys; current alert state may change, while its creation/acknowledgement/resolution actions are audit events. Polymorphic traceability_links are validated against a controlled entity-type registry; normal domain relations continue to use real FKs.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Alerts and traceability">
          <mxGeometry x="40" y="1054" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p7_note3" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Database enforcement&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Use CHECK/UNIQUE/EXCLUDE/partial indexes for local invariants; deferred constraint triggers for same-project and cross-table workflow gates; RLS for project visibility; immutable-table privilege/trigger guards; pgcrypto digest functions; btree_gist for non-overlapping effective periods. All commands are transactionally idempotent.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Database enforcement">
          <mxGeometry x="1345" y="1054" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p7_e0" value="1 stream head to 0..* chained events" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;strokeWidth=1.1;strokeColor=#64748B;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p7_n0" target="p7_n1" dataKind="relationship">
