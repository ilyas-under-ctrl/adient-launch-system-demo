        <mxCell id="p7_n0" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FBE8E7;color:#7F2420;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;audit_stream_heads&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; stream_key varchar(160)&lt;br&gt;last_sequence_no bigint NOT NULL&lt;br&gt;last_event_hash bytea NOT NULL&lt;br&gt;updated_at timestamptz NOT NULL&lt;br&gt;row_version bigint NOT NULL DEFAULT 1&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; internal row locked FOR UPDATE during append&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#B85450;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="audit_stream_heads">
