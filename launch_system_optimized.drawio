        <mxCell id="p2_e4" value="checked current-role cache" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;strokeWidth=1.1;strokeColor=#64748B;fontSize=10;labelBackgroundColor=#FFFFFF;dashed=1;" edge="1" parent="1" source="p2_n0" target="p2_n3" dataKind="relationship">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2_e5" value="1 to 0..*" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;strokeWidth=1.1;strokeColor=#64748B;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="p2_n3" target="p2_n5" dataKind="relationship">
