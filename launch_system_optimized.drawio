        <mxCell id="p5_n17" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#E5F6F6;color:#1D6668;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;warehouse_delivery_documents&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; instruction_id uuid NOT NULL -&amp;gt; warehouse_delivery_instructions&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; document_id uuid NOT NULL -&amp;gt; documents&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; warehouse_leader_id uuid NOT NULL -&amp;gt; users&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; manufacturing_receiver_id uuid NOT NULL -&amp;gt; manufacturing_receivers&lt;br&gt;receiver_name_snapshot varchar(150) NOT NULL&lt;br&gt;generated_at timestamptz NOT NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; instruction_id&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; document_id&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#4FA3A5;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="warehouse_delivery_documents">
          <mxGeometry x="1050" y="1202" width="420" height="253" as="geometry" />
        </mxCell>
        <mxCell id="p5_n18" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#E5F6F6;color:#1D6668;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;warehouse_delivery_receipts&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; warehouse_document_id uuid NOT NULL -&amp;gt; warehouse_delivery_documents&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; signed_document_id uuid NOT NULL -&amp;gt; documents&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; document_signature_id uuid NOT NULL -&amp;gt; document_signatures&lt;br&gt;status signed_document_status NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; uploaded_by uuid NOT NULL -&amp;gt; users&lt;br&gt;uploaded_at timestamptz NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; validated_by uuid NULL -&amp;gt; users&lt;br&gt;validated_at timestamptz NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; inventory_event_id uuid NULL -&amp;gt; inventory_events&lt;br&gt;row_version bigint NOT NULL DEFAULT 1&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; signed_document_id&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; document_signature_id&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; inventory_event_id&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; partial warehouse_document_id WHERE status='validated'&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; partial warehouse_document_id WHERE inventory_event_id IS NOT NULL&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; validator/time may record rejection; event only when validated&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#4FA3A5;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="warehouse_delivery_receipts">
          <mxGeometry x="1555" y="1202" width="420" height="423" as="geometry" />
        </mxCell>
        <mxCell id="p5_n19" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#EAF6EA;color:#2F6B2F;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;v_inventory_balance&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;VIEW / PROJECTION&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;project_id / material_id / location_id&lt;br&gt;on_hand_qty = SUM(inventory_postings.quantity_delta)&lt;br&gt;as_of latest posted event&lt;br&gt;refresh transactionally or incrementally&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#F2F2F2;strokeColor=#9E9E9E;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="view" dataName="v_inventory_balance">
          <mxGeometry x="2060" y="1202" width="420" height="134" as="geometry" />
        </mxCell>
        <mxCell id="p5_n20" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#EAF6EA;color:#2F6B2F;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;v_stock_summary&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;VIEW / PROJECTION&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;project_id / material_id&lt;br&gt;practical_stock from practical pools&lt;br&gt;wip_stock from WIP pools&lt;br&gt;theoretical_stock = practical + open arrivals&lt;br&gt;standard_sim_available = warehouse + usable WIP&lt;br&gt;threshold state derived&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#F2F2F2;strokeColor=#9E9E9E;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="view" dataName="v_stock_summary">
          <mxGeometry x="40" y="1680" width="420" height="168" as="geometry" />
        </mxCell>
        <mxCell id="p5_note0" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Exactly-once posting&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;The service inserts inventory_events and all postings atomically. Repeating an idempotency/source key with the same payload returns the existing result; a different payload hash is rejected. Posted rows cannot be updated/deleted. Corrections and cancellations create linked reversal events.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Exactly-once posting">
          <mxGeometry x="40" y="1918" width="1215" height="109" as="geometry" />
        </mxCell>
        <mxCell id="p5_note1" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Pool scope and arithmetic&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;project_stock_pools explicitly grants a project access to a pool: shared pools may have several active project mappings, while project-scoped pools have exactly one. CutMan imports name both project and pool and require an active mapping. Practical stock excludes transit; simulations separately snapshot warehouse, WIP, transit, and planned components.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Pool scope and arithmetic">
          <mxGeometry x="1345" y="1918" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p5_note2" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Code and receipt gate&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Store only a slow-hash/digest of the human code. Successful generation consumes it once. A warehouse document may receive multiple signed submissions (for correction/retry), but partial unique indexes allow only one validated submission and only one inventory-posting submission for that document. Validation requires a typed signer record and posts the transfer exactly once.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Code and receipt gate">
          <mxGeometry x="40" y="2080" width="1215" height="127" as="geometry" />
        </mxCell>
