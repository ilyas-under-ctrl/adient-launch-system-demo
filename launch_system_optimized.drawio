        <mxCell id="p2_n17" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#E8F1FB;color:#1F4E79;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;fgpns&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; project_id uuid NOT NULL -&amp;gt; projects&lt;br&gt;fgpn_code varchar(32) NOT NULL&lt;br&gt;description varchar(50) NULL&lt;br&gt;active boolean NOT NULL DEFAULT true&lt;br&gt;row_version bigint NOT NULL DEFAULT 1&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (project_id,fgpn_code)&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; format validated by approved project rule&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#6C8EBF;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="fgpns">
