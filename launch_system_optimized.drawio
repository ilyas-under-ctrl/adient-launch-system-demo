        <mxCell id="p5_n1" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#EAF6EA;color:#2F6B2F;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;stock_pools&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; pool_code varchar(30) NOT NULL&lt;br&gt;name varchar(120) NOT NULL&lt;br&gt;pool_type stock_pool_type NOT NULL&lt;br&gt;scope_mode stock_pool_scope NOT NULL&lt;br&gt;included_in_practical boolean NOT NULL&lt;br&gt;included_in_theoretical boolean NOT NULL&lt;br&gt;included_in_standard_sim boolean NOT NULL&lt;br&gt;active boolean NOT NULL DEFAULT true&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="stock_pools">
