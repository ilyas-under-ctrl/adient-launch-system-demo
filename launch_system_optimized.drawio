        <mxCell id="p7_n1" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FBE8E7;color:#7F2420;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;audit_events&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;stream_key varchar(160) NOT NULL&lt;br&gt;sequence_no bigint NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; project_id uuid NULL -&amp;gt; projects&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; user_id uuid NULL -&amp;gt; users&lt;br&gt;event_type varchar(80) NOT NULL&lt;br&gt;entity_type varchar(80) NOT NULL&lt;br&gt;entity_id uuid NOT NULL&lt;br&gt;old_value jsonb NULL&lt;br&gt;new_value jsonb NULL&lt;br&gt;reason text NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; document_id uuid NULL -&amp;gt; documents&lt;br&gt;occurred_at timestamptz NOT NULL&lt;br&gt;prev_hash bytea NOT NULL&lt;br&gt;event_hash bytea NOT NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (stream_key,sequence_no)&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; event_hash&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; hash=sha256(prev_hash+canonical payload)&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; append-only&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#B85450;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="audit_events">
          <mxGeometry x="545" y="125" width="420" height="389" as="geometry" />
        </mxCell>
        <mxCell id="p7_n2" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#EDF1F5;color:#34495E;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;idempotency_requests&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;scope varchar(80) NOT NULL&lt;br&gt;idempotency_key uuid NOT NULL&lt;br&gt;request_hash bytea NOT NULL&lt;br&gt;status idempotency_status NOT NULL&lt;br&gt;response_code integer NULL&lt;br&gt;response_body jsonb NULL&lt;br&gt;created_at timestamptz NOT NULL&lt;br&gt;completed_at timestamptz NULL&lt;br&gt;expires_at timestamptz NOT NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (scope,idempotency_key)&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; key reuse requires same request_hash&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#7B8A97;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="idempotency_requests">
