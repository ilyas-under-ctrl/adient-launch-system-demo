        <mxCell id="p3_n11" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FFF1E6;color:#8A4B08;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;po_status_history&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; purchase_order_id uuid NOT NULL -&amp;gt; purchase_orders&lt;br&gt;sequence_no bigint NOT NULL&lt;br&gt;from_status po_status NULL&lt;br&gt;to_status po_status NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; transition_id smallint NOT NULL -&amp;gt; po_allowed_status_transitions&lt;br&gt;reason text NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; changed_by uuid NOT NULL -&amp;gt; users&lt;br&gt;changed_at timestamptz NOT NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (purchase_order_id,sequence_no)&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; reason required per transition&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; immutable: no UPDATE/DELETE&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#D79B00;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="po_status_history">
          <mxGeometry x="545" y="1047" width="420" height="287" as="geometry" />
        </mxCell>
        <mxCell id="p3_n12" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FFF1E6;color:#8A4B08;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;production_events&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; project_id uuid NOT NULL -&amp;gt; projects&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; launch_operation_id uuid NOT NULL -&amp;gt; launch_operations&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; idempotency_key uuid NOT NULL&lt;br&gt;source_system varchar(40) NOT NULL&lt;br&gt;source_event_key varchar(120) NOT NULL&lt;br&gt;payload_hash bytea NOT NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; evidence_document_id uuid NULL -&amp;gt; documents&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; recorded_by uuid NOT NULL -&amp;gt; users&lt;br&gt;occurred_at timestamptz NOT NULL&lt;br&gt;recorded_at timestamptz NOT NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (source_system,source_event_key)&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; immutable; key reuse requires same payload hash&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#D79B00;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="production_events">
          <mxGeometry x="1050" y="1047" width="420" height="287" as="geometry" />
        </mxCell>
        <mxCell id="p3_n13" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FFF1E6;color:#8A4B08;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;production_event_items&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; production_event_id uuid NOT NULL -&amp;gt; production_events&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; po_item_id uuid NOT NULL -&amp;gt; purchase_order_items&lt;br&gt;line_no integer NOT NULL&lt;br&gt;quantity_produced numeric(20,4) NOT NULL&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (production_event_id,line_no)&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (production_event_id,po_item_id)&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; quantity_produced&amp;gt;0; immutable partial-production fact&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#D79B00;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="production_event_items">
          <mxGeometry x="1555" y="1047" width="420" height="202" as="geometry" />
        </mxCell>
        <mxCell id="p3_n14" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FFF1E6;color:#8A4B08;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;v_po_item_balance&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;VIEW / PROJECTION&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;po_item_id uuid&lt;br&gt;ordered_qty from current immutable PO version&lt;br&gt;launched_qty from launch_operation_items&lt;br&gt;produced_qty from production_event_items&lt;br&gt;in_manufacturing_qty = launched-produced&lt;br&gt;confirmed_delivered_qty from confirmed customer_delivery_lines&lt;br&gt;remaining_to_launch / remaining_to_deliver&lt;br&gt;amount_remaining and ISO weeks generated at query&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#F2F2F2;strokeColor=#9E9E9E;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="view" dataName="v_po_item_balance">
          <mxGeometry x="2060" y="1047" width="420" height="219" as="geometry" />
        </mxCell>
        <mxCell id="p3_note0" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;20-field extraction coverage&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;po_field_key contains: jit_customer, contact_information, document_date, delivery_date, item, fgpn, development_level, quantity, unit_price, reason_of_po, po_number, delivery_week, car_model, engineering_phase_level, color_code, description, trim_code, po_level, pickup_date, pickup_week. Derived weeks are still stored as reviewed extraction values; authoritative weeks are generated from dates.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="20-field extraction coverage">
          <mxGeometry x="40" y="1404" width="1215" height="145" as="geometry" />
        </mxCell>
        <mxCell id="p3_note1" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Stable item invariant&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;A version row never becomes the identity used by deliveries or launch operations. purchase_order_items is the durable identity; every version maps its lines to that identity. Added lines get new stable items, removed lines simply do not appear in the later immutable snapshot, and ambiguous matching requires user confirmation.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Stable item invariant">
          <mxGeometry x="1345" y="1404" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p3_note2" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Version/status invariant&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;Versions and their item rows are append-only and copy customer, contact, FGPN, and development-level display values so history survives master-data edits. purchase_orders.current_version_id/current_status are checked caches. Each from/to transition is unique; any number of allowed roles is attached through po_status_transition_roles.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Version/status invariant">
          <mxGeometry x="40" y="1584" width="1215" height="127" as="geometry" />
        </mxCell>
        <mxCell id="p3_note3" value="&lt;div style=&quot;font-family:Arial;color:#5F4B00;font-size:13px;line-height:1.35&quot;&gt;&lt;b&gt;Typed progress invariant&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:11px&quot;&gt;There is no polymorphic progress table. Launched quantity comes only from launch_operation_items, partial produced quantity from append-only production_event_items, and delivered quantity only from confirmed customer_delivery_lines. v_po_item_balance joins those typed stable-PO-item facts; deferred checks prevent produced&amp;gt;launched or delivered&amp;gt;produced.&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFF9D9;strokeColor=#D6B656;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;dashed=1;spacing=10;" vertex="1" parent="1" dataKind="note" dataName="Typed progress invariant">
          <mxGeometry x="1345" y="1584" width="1215" height="127" as="geometry" />
        </mxCell>
