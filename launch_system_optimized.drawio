        <mxCell id="p3_n9" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#FFF1E6;color:#8A4B08;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;po_allowed_status_transitions&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id smallint&lt;br&gt;from_status po_status NOT NULL&lt;br&gt;to_status po_status NOT NULL&lt;br&gt;direction transition_direction NOT NULL&lt;br&gt;requires_reason boolean NOT NULL&lt;br&gt;active boolean NOT NULL DEFAULT true&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (from_status,to_status)&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#D79B00;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="po_allowed_status_transitions">
