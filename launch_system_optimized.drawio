        <mxCell id="p5_n2" value="&lt;div style=&quot;font-family:Consolas,Arial;color:#263238;font-size:10px;line-height:1.35&quot;&gt;&lt;div style=&quot;background-color:#EAF6EA;color:#2F6B2F;font-family:Arial;font-size:13px;padding:5px&quot;&gt;&lt;b&gt;project_stock_pools&lt;/b&gt; &lt;span style=&quot;font-size:9px&quot;&gt;TABLE&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;padding:7px;text-align:left&quot;&gt;&lt;span style=&quot;color:#7F2420;font-weight:700&quot;&gt;PK&lt;/span&gt; id uuid&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; project_id uuid NOT NULL -&amp;gt; projects&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; stock_pool_id uuid NOT NULL -&amp;gt; stock_pools&lt;br&gt;effective_from timestamptz NOT NULL&lt;br&gt;effective_to timestamptz NULL&lt;br&gt;&lt;span style=&quot;color:#1F4E79;font-weight:700&quot;&gt;FK&lt;/span&gt; mapped_by uuid NOT NULL -&amp;gt; users&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; (project_id,stock_pool_id,effective_from)&lt;br&gt;&lt;span style=&quot;color:#6A1B9A;font-weight:700&quot;&gt;UQ&lt;/span&gt; partial (project_id,stock_pool_id) WHERE effective_to IS NULL&lt;br&gt;EXCLUDE overlapping membership per project/pool&lt;br&gt;&lt;span style=&quot;color:#2F6B2F;font-weight:700&quot;&gt;CK&lt;/span&gt; project-scoped pool has one project; shared pool may map many&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;shadow=0;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=1.4;align=left;verticalAlign=top;spacing=0;" vertex="1" parent="1" dataKind="table" dataName="project_stock_pools">
