  response_code integer
  response_body jsonb
  created_at timestamptz [not null]
  completed_at timestamptz
  expires_at timestamptz [not null]

  indexes {
    (scope, idempotency_key) [unique, name: 'unique_idempotency_requests_scope_idempotency_key']
  }

  Note: '''
  CHECK/constraint-trigger rule (documentary in DBML): key reuse requires same request_hash.
  '''
}

// Module: audit
Table outbox_events {
  id uuid [pk]
  audit_event_id uuid
  aggregate_type varchar(80) [not null]
  aggregate_id uuid [not null]
  event_type varchar(100) [not null]
  topic varchar(120) [not null]
  payload jsonb [not null]
  occurred_at timestamptz [not null]
  available_at timestamptz [not null]
  published_at timestamptz
  attempt_count integer [not null, default: 0]
  last_error text

  indexes {
    audit_event_id [unique, name: 'unique_outbox_events_audit_event_id']
    (aggregate_type, aggregate_id, event_type, occurred_at) [unique, name: 'unique_outbox_events_aggregate_type_aggregate_id_event_3a60f863']
  }

  Note: '''
  Transactional-outbox rule: the business fact, audit event, and outbox row commit atomically. A worker retries publication and sets published_at only after success; consumers deduplicate by outbox event id. DBML documents, but cannot enforce, the transaction and worker protocol.
  '''
}

// Module: audit
Table dashboard_alerts {
  id uuid [pk]
