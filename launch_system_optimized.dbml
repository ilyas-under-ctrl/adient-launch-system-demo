// Module: audit
Table audit_events {
  id uuid [pk]
  stream_key varchar(160) [not null]
  sequence_no bigint [not null]
  project_id uuid
  user_id uuid
  event_type varchar(80) [not null]
  entity_type varchar(80) [not null]
  entity_id uuid [not null]
  old_value jsonb
  new_value jsonb
  reason text
  document_id uuid
  occurred_at timestamptz [not null]
  prev_hash bytea [not null]
  event_hash bytea [not null]

  indexes {
    (stream_key, sequence_no) [unique, name: 'unique_audit_events_stream_key_sequence_no']
    event_hash [unique, name: 'unique_audit_events_event_hash']
    project_id [name: 'ix_audit_events_project_id']
    user_id [name: 'ix_audit_events_user_id']
    document_id [name: 'ix_audit_events_document_id']
  }

  Note: '''
  CHECK/constraint-trigger rule (documentary in DBML): hash=sha256(prev_hash+canonical payload).
  CHECK/constraint-trigger rule (documentary in DBML): append-only.
  Append-only enforcement requires privileges plus a guard trigger; DBML cannot enforce UPDATE/DELETE/TRUNCATE revocation.
  RLS policy required on project_id; DBML does not implement row-level security.
  '''
}

// Module: cross
Table idempotency_requests {
  id uuid [pk]
  scope varchar(80) [not null]
  idempotency_key uuid [not null]
