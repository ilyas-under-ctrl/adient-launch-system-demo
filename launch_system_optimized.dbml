}

// Module: iam
Table material_types {
  id uuid [pk]
  type_code varchar(40) [unique, not null]
  name varchar(120) [not null]
  active boolean [not null, default: true]
  row_version bigint [not null, default: 1]
}

// Module: iam
Table projects {
  id uuid [pk]
  project_code varchar(30) [unique, not null]
  project_name varchar(150) [not null]
  customer_id uuid [not null]
  status project_status [not null]
  created_by uuid [not null]
  row_version bigint [not null, default: 1]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  indexes {
    customer_id [name: 'ix_projects_customer_id']
    created_by [name: 'ix_projects_created_by']
  }
}

// Module: iam
Table project_development_levels {
  id uuid [pk]
  project_id uuid [not null]
  level_code varchar(40) [not null]
  name varchar(120) [not null]
  sort_order smallint [not null]
  active boolean [not null, default: true]
  row_version bigint [not null, default: 1]

  indexes {
    (project_id, level_code) [unique, name: 'unique_project_development_levels_project_id_level_code']
    project_id [name: 'ix_project_development_levels_project_id']
  }

  Note: '''
  RLS policy required on project_id; DBML does not implement row-level security.
  '''
}

// Module: iam
Table project_assignments {
  id uuid [pk]
  project_id uuid [not null]
  user_id uuid [not null]
  assigned_by uuid [not null]
  assigned_at timestamptz [not null]
  unassigned_by uuid
  unassigned_at timestamptz
  unassignment_reason text

  indexes {
    project_id [name: 'ix_project_assignments_project_id']
    user_id [name: 'ix_project_assignments_user_id']
    assigned_by [name: 'ix_project_assignments_assigned_by']
    unassigned_by [name: 'ix_project_assignments_unassigned_by']
  }

  Note: '''
  PostgreSQL partial UNIQUE rule (not expressible in DBML): (project_id,user_id) WHERE unassigned_at IS NULL.
  CHECK/constraint-trigger rule (documentary in DBML): unassigned_at>assigned_at when set; immutable history.
  Append-only enforcement requires privileges plus a guard trigger; DBML cannot enforce UPDATE/DELETE/TRUNCATE revocation.
  RLS policy required on project_id; DBML does not implement row-level security.
  '''
}

// Module: iam
Table reference_list_types {
  id smallint [pk]
  code varchar(40) [unique, not null]
  name varchar(100) [not null]
  scope reference_scope [not null]
  active boolean [not null, default: true]
}

// Module: iam
Table reference_list_items {
  id uuid [pk]
  type_id smallint [not null]
  project_id uuid
  code varchar(80)
  label varchar(150) [not null]
  active boolean [not null, default: true]
  created_by uuid [not null]
  row_version bigint [not null, default: 1]
  created_at timestamptz [not null]
  deactivated_at timestamptz

  indexes {
    type_id [name: 'ix_reference_list_items_type_id']
    project_id [name: 'ix_reference_list_items_project_id']
    created_by [name: 'ix_reference_list_items_created_by']
  }

  Note: '''
  PostgreSQL UNIQUE NULLS NOT DISTINCT rule (not expressible in DBML): (type_id,project_id,code).
  CHECK/constraint-trigger rule (documentary in DBML): non-authoritative extension values only.
  RLS policy required on project_id; DBML does not implement row-level security.
  '''
}

// Module: iam
Table fgpns {
  id uuid [pk]
  project_id uuid [not null]
  fgpn_code varchar(32) [not null]
  description varchar(50)
  active boolean [not null, default: true]
  row_version bigint [not null, default: 1]

  indexes {
    (project_id, fgpn_code) [unique, name: 'unique_fgpns_project_id_fgpn_code']
    project_id [name: 'ix_fgpns_project_id']
  }

  Note: '''
  CHECK/constraint-trigger rule (documentary in DBML): format validated by approved project rule.
  RLS policy required on project_id; DBML does not implement row-level security.
  '''
}

// Module: iam
Table document_encryption_keys {
  id uuid [pk]
  provider varchar(40) [not null]
  kms_key_ref varchar(255) [not null]
  key_version varchar(80) [not null]
  algorithm varchar(40) [not null]
  status key_status [not null]
  activated_at timestamptz [not null]
  retired_at timestamptz

  indexes {
    (kms_key_ref, key_version) [unique, name: 'unique_document_encryption_keys_kms_key_ref_key_version']
  }

  Note: '''
  CHECK/constraint-trigger rule (documentary in DBML): external KMS reference only; never key material.
  '''
}

// Module: iam
Table documents {
  id uuid [pk]
  document_type varchar(40) [not null, note: 'Extensible document-type code; MIME/extension/content checks belong in PostgreSQL DDL and upload validation.']
  file_name varchar(255) [not null]
  mime_type varchar(100) [not null]
  byte_size bigint [not null]
  storage_key text [unique, not null]
  checksum_sha256 bytea [not null]
  encryption_key_id uuid [not null]
  retention_class varchar(60) [not null]
  retain_until timestamptz
  legal_hold boolean [not null, default: false]
  status document_status [not null]
  uploaded_by uuid
  uploaded_at timestamptz [not null]

  indexes {
    checksum_sha256 [name: 'ix_documents_checksum_sha256']
    encryption_key_id [name: 'ix_documents_encryption_key_id']
    uploaded_by [name: 'ix_documents_uploaded_by']
  }

  Note: '''
  CHECK/constraint-trigger rule (documentary in DBML): byte_size>0; purge blocked by hold/retention.
  '''
}

// Module: iam
Table document_signatures {
  id uuid [pk]
  document_id uuid [not null]
  manufacturing_receiver_id uuid
  signer_user_id uuid
  signer_name_snapshot varchar(150) [not null]
  signature_role varchar(80) [not null]
  uploaded_by uuid [not null]
  signed_at timestamptz
  recorded_at timestamptz [not null]

  indexes {
    (document_id, signature_role, signer_name_snapshot) [unique, name: 'unique_document_signatures_document_id_signature_role__b3784636']
    document_id [name: 'ix_document_signatures_document_id']
    manufacturing_receiver_id [name: 'ix_document_signatures_manufacturing_receiver_id']
    signer_user_id [name: 'ix_document_signatures_signer_user_id']
    uploaded_by [name: 'ix_document_signatures_uploaded_by']
  }

  Note: '''
  CHECK/constraint-trigger rule (documentary in DBML): exactly one typed signer identity when known.
  '''
}

// Module: cross
Table system_settings {
  setting_key varchar(100) [pk]
  setting_value jsonb [not null]
  value_schema_version integer [not null]
  updated_by uuid [not null]
  updated_at timestamptz [not null]
  row_version bigint [not null, default: 1]

  indexes {
    updated_by [name: 'ix_system_settings_updated_by']
  }
}

// Module: po
Table po_uploads {
  id uuid [pk]
  project_id uuid [not null]
  document_id uuid [not null]
  uploaded_by uuid [not null]
  uploaded_at timestamptz [not null]
  status po_upload_status [not null]
  rejection_reason text

  indexes {
    document_id [unique, name: 'unique_po_uploads_document_id']
    project_id [name: 'ix_po_uploads_project_id']
    uploaded_by [name: 'ix_po_uploads_uploaded_by']
  }

  Note: '''
  CHECK/constraint-trigger rule (documentary in DBML): document is PDF; stored even if rejected.
  RLS policy required on project_id; DBML does not implement row-level security.
  '''
}

// Module: po
Table po_extraction_runs {
  id uuid [pk]
  po_upload_id uuid [not null]
  attempt_no smallint [not null]
  parser_name varchar(80) [not null]
  parser_version varchar(40) [not null]
  status extraction_status [not null]
  started_at timestamptz [not null]
  completed_at timestamptz
  error_message text

  indexes {
    (po_upload_id, attempt_no) [unique, name: 'unique_po_extraction_runs_po_upload_id_attempt_no']
    po_upload_id [name: 'ix_po_extraction_runs_po_upload_id']
  }
}

// Module: po
Table po_extracted_values {
  id uuid [pk]
  extraction_run_id uuid [not null]
  line_ordinal integer [not null, default: 0]
  field_key po_field_key [not null]
  raw_text text
  extracted_value text
  corrected_value text
  final_value text
  validation_status validation_status [not null]
  validation_message text
  expected_value text
  corrected_by uuid
  corrected_at timestamptz

  indexes {
    (extraction_run_id, line_ordinal, field_key) [unique, name: 'unique_po_extracted_values_extraction_run_id_line_ordi_226f04a5']
    extraction_run_id [name: 'ix_po_extracted_values_extraction_run_id']
    corrected_by [name: 'ix_po_extracted_values_corrected_by']
  }

  Note: '''
  CHECK/constraint-trigger rule (documentary in DBML): line_ordinal=0 header; >0 line.
  '''
}

// Module: po
Table purchase_orders {
  id uuid [pk]
  project_id uuid [not null]
  po_number char(10) [not null]
  current_version_id uuid
  current_status po_status [not null]
  created_by uuid [not null]
  created_at timestamptz [not null]
  row_version bigint [not null, default: 1]

  indexes {
    (project_id, po_number) [unique, name: 'unique_purchase_orders_project_id_po_number']
    project_id [name: 'ix_purchase_orders_project_id']
    current_version_id [name: 'ix_purchase_orders_current_version_id']
    created_by [name: 'ix_purchase_orders_created_by']
  }

  Note: '''
  CHECK/constraint-trigger rule (documentary in DBML): length(po_number)=10.
  RLS policy required on project_id; DBML does not implement row-level security.
  '''
}

// Module: po
Table purchase_order_items {
  id uuid [pk]
  purchase_order_id uuid [not null]
  stable_item_key uuid [unique, not null]
  external_item_key varchar(80)
  created_at timestamptz [not null]
  retired_at timestamptz

  indexes {
    (purchase_order_id, external_item_key) [name: 'ix_purchase_order_items_purchase_order_id_external_item_key']
    purchase_order_id [name: 'ix_purchase_order_items_purchase_order_id']
  }
}

// Module: po
Table purchase_order_versions {
  id uuid [pk]
  purchase_order_id uuid [not null]
  po_upload_id uuid [not null]
  version_no integer [not null]
  customer_id uuid [not null]
  customer_contact_id uuid [not null]
  customer_code_snapshot varchar(40) [not null]
  customer_name_snapshot varchar(180) [not null]
  contact_name_snapshot varchar(150) [not null]
  contact_details_snapshot jsonb [not null]
  document_date date [not null]
  reason_of_po text [not null]
  car_model varchar(80)
  confirmed_by uuid [not null]
  confirmed_at timestamptz [not null]
  content_hash bytea [not null]

  indexes {
    (purchase_order_id, version_no) [unique, name: 'unique_purchase_order_versions_purchase_order_id_version_no']
    (purchase_order_id, content_hash) [unique, name: 'unique_purchase_order_versions_purchase_order_id_content_hash']
    purchase_order_id [name: 'ix_purchase_order_versions_purchase_order_id']
    po_upload_id [name: 'ix_purchase_order_versions_po_upload_id']
    customer_id [name: 'ix_purchase_order_versions_customer_id']
    customer_contact_id [name: 'ix_purchase_order_versions_customer_contact_id']
    confirmed_by [name: 'ix_purchase_order_versions_confirmed_by']
  }

  Note: '''
  CHECK/constraint-trigger rule (documentary in DBML): contact belongs customer; customer matches project.
  CHECK/constraint-trigger rule (documentary in DBML): immutable: no UPDATE/DELETE.
  Append-only enforcement requires privileges plus a guard trigger; DBML cannot enforce UPDATE/DELETE/TRUNCATE revocation.
  '''
}

// Module: po
Table purchase_order_version_items {
  id uuid [pk]
  po_version_id uuid [not null]
  po_item_id uuid [not null]
  line_number integer [not null]
  item varchar(80) [not null]
  part_number char(7)
  fgpn_id uuid [not null]
  fgpn_code_snapshot varchar(32) [not null]
  development_level_id uuid [not null]
  development_level_code_snapshot varchar(40) [not null]
  engineering_phase_level varchar(40)
  color_code char(4)
  description varchar(50)
  trim_code varchar(40)
  po_level varchar(6)
  quantity numeric(20,4) [not null]
  unit_price numeric(20,4) [not null]
  delivery_date date [not null]
  pickup_date date
  row_hash bytea [not null]

  indexes {
    (po_version_id, po_item_id) [unique, name: 'unique_purchase_order_version_items_po_version_id_po_item_id']
    (po_version_id, line_number) [unique, name: 'unique_purchase_order_version_items_po_version_id_line_number']
