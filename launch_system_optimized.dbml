  phone varchar(40)
  active boolean [not null, default: true]
  row_version bigint [not null, default: 1]

  indexes {
    (customer_id, contact_code) [unique, name: 'unique_customer_contacts_customer_id_contact_code']
    customer_id [name: 'ix_customer_contacts_customer_id']
  }
}

// Module: iam
Table manufacturing_receivers {
  id uuid [pk]
  receiver_code varchar(60) [unique, not null]
