// Module: iam
Table roles {
  id smallint [pk]
  code role_code [unique, not null]
  name varchar(80) [not null]
  active boolean [not null, default: true]
}

// Module: iam
Table permissions {
  id smallint [pk]
  code varchar(80) [unique, not null, note: 'Extensible permission code governed by seeded policy data.']
  name varchar(120) [not null]
  description text
  active boolean [not null, default: true]
}

// Module: iam
Table role_permissions {
  role_id smallint [not null]
  permission_id smallint [not null]
  granted_by uuid
  granted_at timestamptz [not null]

  indexes {
    (role_id, permission_id) [pk, name: 'pk_role_permissions_role_id_permission_id']
    role_id [name: 'ix_role_permissions_role_id']
    permission_id [name: 'ix_role_permissions_permission_id']
    granted_by [name: 'ix_role_permissions_granted_by']
  }

  Note: '''
  CHECK/constraint-trigger rule (documentary in DBML): rows are append-only policy data.
  Append-only enforcement requires privileges plus a guard trigger; DBML cannot enforce UPDATE/DELETE/TRUNCATE revocation.
  '''
}

// Module: iam
Table users {
  id uuid [pk]
  current_role_id smallint
  username citext [unique, not null]
  password_hash text [not null]
  status user_status [not null]
  failed_login_count smallint [not null, default: 0]
  locked_at timestamptz
  deactivated_at timestamptz
  row_version bigint [not null, default: 1]
  created_at timestamptz [not null]

  indexes {
    current_role_id [name: 'ix_users_current_role_id']
  }

  Note: '''
  CHECK/constraint-trigger rule (documentary in DBML): active user has exactly one open role assignment.
  CHECK/constraint-trigger rule (documentary in DBML): current_role_id is a trigger-checked cache.
  '''
}

// Module: iam
Table user_role_assignments {
  id uuid [pk]
  user_id uuid [not null]
  role_id smallint [not null]
  assigned_by uuid [not null]
  assigned_at timestamptz [not null]
  ended_by uuid
  ended_at timestamptz
  reason text

  indexes {
    user_id [name: 'ix_user_role_assignments_user_id']
    role_id [name: 'ix_user_role_assignments_role_id']
    assigned_by [name: 'ix_user_role_assignments_assigned_by']
    ended_by [name: 'ix_user_role_assignments_ended_by']
  }

  Note: '''
  PostgreSQL partial UNIQUE rule (not expressible in DBML): user_id WHERE ended_at IS NULL.
  CHECK/constraint-trigger rule (documentary in DBML): ended_at>assigned_at when set; immutable history.
  Append-only enforcement requires privileges plus a guard trigger; DBML cannot enforce UPDATE/DELETE/TRUNCATE revocation.
  '''
}

// Module: iam
Table user_sessions {
  id uuid [pk]
  user_id uuid [not null]
  token_digest bytea [unique, not null]
  created_at timestamptz [not null]
  last_seen_at timestamptz [not null]
  expires_at timestamptz [not null]
  revoked_at timestamptz
  ip_address inet
  user_agent text

  indexes {
    user_id [name: 'ix_user_sessions_user_id']
  }

  Note: '''
  CHECK/constraint-trigger rule (documentary in DBML): expires_at > created_at.
  '''
}

// Module: iam
Table login_events {
  id bigint [pk, increment]
  user_id uuid
  username_entered citext [not null]
  success boolean [not null]
  failure_reason varchar(80)
  occurred_at timestamptz [not null]
  ip_address inet

  indexes {
    (username_entered, occurred_at) [name: 'ix_login_events_username_entered_occurred_at']
    user_id [name: 'ix_login_events_user_id']
  }
}

// Module: iam
Table customers {
